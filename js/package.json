{
  "name": "mtph",
  "version": "0.2.0",
  "description": "AI-native format for math & physics problems — parser, validator, renderer.",
  "type": "module",
  "license": "MIT",
  "exports": { ".": "./src/index.ts" },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "build:web": "esbuild web/app.ts --bundle --format=iife --outfile=../playground/app.js --loader:.json=json --loader:.mtph=text --minify --sourcemap",
    "build:webcomponent": "esbuild web/mtph-doc.ts --bundle --format=iife --outfile=../playground/mtph-doc.js --loader:.json=json --minify --sourcemap"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "lz-string": "^1.5.0"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "yaml": "^2.5.0"
  }
}
