# B-field coils (mirror coils)
rect at=(-4,0.3) w=8 h=0.3 fill=gray
rect at=(-4,7.4) w=8 h=0.3 fill=gray

# Particle helical trajectory (gyrating)
path d="M(0.5,1) C(0.3,1.5)(-0.1,1.5)(0.1,2) C(0.3,2.5)(-0.2,2.5)(0,3) C(0.2,3.5)(-0.1,3.5)(0.1,4) C(0.3,4.5)(-0.2,4.5)(0.05,5) C(0.2,5.5)(-0.1,5.5)(0.1,6) C(0.2,6.5)(-0.05,6.5)(0.1,7)" style=solid width=1.2

# Velocity vector at a point
vector from=(0.2,4.5) to=(0.6,5.19) label="\mathbf{v}"
