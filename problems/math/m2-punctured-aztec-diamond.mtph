# Outer diamond boundary (tilted 45 degrees)
# Coordinates: diamond of "radius" 4 units in checkerboard
path d="M(0,4) L(4,0) L(8,4) L(4,8) Z" fill=none stroke=black width=0.6

# Horizontal-ish lines (rows of squares)
path d="M(1,3) L(7,3)" stroke=gray style=dashed width=0.3
